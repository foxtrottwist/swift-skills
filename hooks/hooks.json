{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/swift-skill-nudge.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/swift-patterns.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__xcode__BuildProject|mcp__xcode__RunAllTests|mcp__xcode__RunSomeTests",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/swizzle-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
